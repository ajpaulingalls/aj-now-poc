{
  "expo": {
    "name": "AJ Now",
    "slug": "aj-now",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "aj-now",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aljazeera.ajnow"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.aljazeera.ajnow"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "AJ Now needs camera access for field reporting.",
          "microphonePermission": "AJ Now needs microphone access for audio recording.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "AJ Now needs your location for safety tracking and story geo-tagging."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "AJ Now uses Face ID to protect your account and stories."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
